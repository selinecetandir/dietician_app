{
  "rules": {
    "users": {
      ".indexOn": ["role"],
      ".read": true,
      ".write": true
    },
    "appointments": {
      ".indexOn": ["patientId", "dietitianId"],
      ".read": true,
      ".write": true
    },
    "timeSlots": {
      ".indexOn": ["dietitianId"],
      ".read": true,
      ".write": true
    },
    "dietPlans": {
      ".indexOn": ["patientId"],
      ".read": true,
      ".write": true
    },
    "weightEntries": {
      ".indexOn": ["patientId"],
      ".read": true,
      ".write": true
    },
    "bloodTests": {
      ".read": true,
      ".write": true
    },
    "patientDocuments": {
      ".read": true,
      ".write": true
    },
    "notifications": {
      ".read": true,
      ".write": true
    }
  }
}
